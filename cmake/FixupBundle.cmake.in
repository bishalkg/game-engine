if(NOT APPLE)
  message(FATAL_ERROR "FixupBundle.cmake should only run on macOS.")
endif()

if(NOT DEFINED APP_BUNDLE OR APP_BUNDLE STREQUAL "")
  message(FATAL_ERROR "APP_BUNDLE was not provided.")
endif()

include(BundleUtilities)

set(FIXUP_SEARCH_DIRS "@BUNDLE_FIXUP_SEARCH_DIRS@")
list(APPEND FIXUP_SEARCH_DIRS
  "${APP_BUNDLE}/Contents/MacOS"
  "${APP_BUNDLE}/Contents/Frameworks"
)

message(STATUS "Fixing bundle dependencies for: ${APP_BUNDLE}")
message(STATUS "Fixup search dirs: ${FIXUP_SEARCH_DIRS}")

fixup_bundle("${APP_BUNDLE}" "" "${FIXUP_SEARCH_DIRS}")
